# Local Jellyfin dev environment for this plugin
#
# Copy to dev/.env and edit as needed.
# These defaults are safe for local use.

# Host ports
JELLYFIN_HTTP_PORT=8096

# Container paths
# /config is where Jellyfin stores configuration and plugins in Docker
# /cache is optional but recommended
# /inbox is where we'll write uploaded files (mounted from ./dev/inbox)

# Image tag (keep "latest" for dev; pin in production)
JELLYFIN_IMAGE=jellyfin/jellyfin:latest
